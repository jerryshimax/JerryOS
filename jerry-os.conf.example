#!/usr/bin/env bash
# jerry-os.conf — JerryOS Configuration
# Copy this file to jerry-os.conf and fill in your details.
# Then run: ./setup.sh

# ─── Your Identity ──────────────────────────────────────
# Used in CLAUDE.md so Claude knows who you are
USER_NAME="Your Name"
USER_ROLE="your role (e.g., crypto trader, researcher, startup founder)"
USER_BIO="A short paragraph about who you are and what you do.
Claude reads this to understand your context and tailor its help."

# ─── Paths ──────────────────────────────────────────────
# Where your Obsidian vault will live
BRAIN_PATH="$HOME/Brain"

# Where your file system root lives (Google Drive, Dropbox, or local)
WORK_PATH="$HOME/Work"

# Where code projects live
SHIP_PATH="$HOME/Ship"

# ─── Entities ───────────────────────────────────────────
# Organizations or contexts you work across.
# Format: "TAG:Full Name:Description"
# TAG = short uppercase identifier used in filenames
# The first entity is your primary one.
#
# Examples for different users:
#   Crypto trader: ("TRADE:Alpha Trading:Main trading activity" "RES:DeFi Research:Research arm")
#   Startup founder: ("CO:My Startup:Main company" "SIDE:Side Project:Weekend project")
#   Freelancer: ("CLIENT1:Acme Corp:Biggest client" "CLIENT2:Beta Inc:Second client")

ENTITIES=(
  "ORG1:Organization One:Your primary organization"
  "ORG2:Organization Two:Your secondary organization"
)

# ─── Modules ────────────────────────────────────────────
# Toggle which modules to install. Set to true or false.

# Full-text search across your vault (recommended)
ENABLE_MCP_MEMORY=true

# Google Tasks integration (needs Google Cloud OAuth)
ENABLE_MCP_GOOGLE_TASKS=false

# Multi-model adversarial analysis (needs OpenAI + Google AI + xAI API keys)
ENABLE_ARENA=false

# Telegram AI assistant bot (needs Telegram bot token)
ENABLE_CLOUD_BOT=false

# Self-improving skill detection
ENABLE_SKILL_ENGINE=false

# Daily log rotation for Ship logs
ENABLE_LOG_ROTATE=true
